<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Home</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white min-h-screen flex flex-col">

  <!-- Navbar -->
  <header class="bg-zinc-800 sticky top-0 z-10 border-b border-zinc-700">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight">Mosaic</a>
      <nav class="flex items-center gap-2">
        <% if (user) { %>
          <span class="hidden sm:inline text-zinc-300 mr-2">Hi, <%= user.username || user.email %></span>
          <a href="/posts/new" class="bg-blue-600 hover:bg-blue-700 px-3 py-2 rounded-md">New Post</a>
          <a href="/dashboard" class="bg-zinc-700 hover:bg-zinc-600 px-3 py-2 rounded-md">Dashboard</a>
          <a href="/logout" class="bg-zinc-700 hover:bg-zinc-600 px-3 py-2 rounded-md">Logout</a>
        <% } else { %>
          <a href="/login" class="bg-blue-600 hover:bg-blue-700 px-3 py-2 rounded-md">Login</a>
          <a href="/register" class="bg-zinc-700 hover:bg-zinc-600 px-3 py-2 rounded-md">Register</a>
        <% } %>
      </nav>
    </div>
  </header>

 
  <main class="flex-1">
    <section class="border-b border-zinc-800">
      <div class="max-w-6xl mx-auto px-4 py-10">
        <h1 class="text-3xl font-bold">What’s new today?</h1>
        <p class="text-zinc-400 mt-2">Latest posts from everyone.</p>
      </div>
    </section>

 
    <section>
      <div class="max-w-6xl mx-auto px-4 py-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

        <% if (!posts || !posts.length) { %>
          <p class="text-zinc-400">No posts yet.</p>
        <% } %>

        <% posts?.forEach(p => { %>
          <article class="rounded-2xl overflow-hidden border border-zinc-700 bg-zinc-800/80 shadow-sm hover:shadow-md transition-shadow">
         
            <div class="relative w-full overflow-hidden bg-zinc-900">
             
              <div class="aspect-[1/1] sm:aspect-[4/3] lg:aspect-[16/10]">
                <img
                  src="<%= p.imageUrl %>"
                  alt="<%= p.title %>"
                  class="w-full h-full object-cover transition-transform duration-300 ease-out hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                  onerror="this.onerror=null; this.src='/placeholder.jpg';"
                />
              </div>
             
              <div class="pointer-events-none absolute inset-x-0 top-0 h-12 bg-gradient-to-b from-black/20 to-transparent"></div>
            </div>

           
            <div class="p-4">
              <h2 class="text-lg font-semibold leading-tight"><%= p.title %></h2>
              <p class="text-sm text-zinc-400 mt-1">
                by <%= p.userId?.username || p.userId?.email || 'Unknown' %> ·
                <%= new Date(p.createdAt).toLocaleString() %>
              </p>

              <div class="mt-4 flex items-center gap-2">
                <% if (user) { %>
                  <form method="post" action="/posts/<%= p._id %>/<%= p.likedByMe ? 'unlike' : 'like' %>">
                    <button class="px-3 py-1 rounded-md text-sm
                                   <%= p.likedByMe ? 'bg-green-600 hover:bg-green-700' : 'bg-zinc-700 hover:bg-zinc-600' %>">
                      <%= p.likedByMe ? 'Unlike' : 'Like' %> (<%= p.likesCount %>)
                    </button>
                  </form>
                <% } else { %>
                  <span class="px-3 py-1 rounded bg-zinc-700 text-sm">Likes: <%= p.likesCount %></span>
                <% } %>

              <% if (user && (String(p.userId?._id) === String(user._id) || user.role === 'admin')) { %>
  <form method="post" action="/posts/<%= p._id %>/delete" onsubmit="return confirm('Delete this post?')">
    <button class="px-3 py-1 rounded-md text-sm bg-red-600 hover:bg-red-700">
      <%= user.role === 'admin' ? 'Admin Delete' : 'Delete' %>
    </button>
  </form>
<% } %>

              </div>
            </div>
          </article>
        <% }) %>

      </div>
    </section>
  </main>

  <footer class="border-t border-zinc-800">
    <div class="max-w-6xl mx-auto px-4 py-6 text-sm text-zinc-500">
      © <%= new Date().getFullYear() %> Mosaic. All rights reserved.
    </div>
  </footer>
</body>
</html>
