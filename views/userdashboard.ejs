<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= user?.username || user?.email || 'Dashboard' %> — Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex flex-col">

 
  <header class="bg-zinc-900/80 backdrop-blur border-b border-zinc-800">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 grid place-items-center font-bold">
          <span>M</span>
        </div>
        <h1 class="text-lg sm:text-xl font-semibold">Welcome, <span class="text-blue-400"><%= user.email %></span></h1>
      </div>
      <nav class="flex items-center gap-2">
        <a href="/" class="px-3 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700">Home</a>
        <a href="/feed" class="px-3 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700">Feed</a>
        <a href="/logout" class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700">Logout</a>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <div class="max-w-6xl mx-auto px-4 py-8 space-y-8">

     
      <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
     
        <div class="group bg-zinc-900 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition p-6">
          <p class="text-zinc-400 text-sm mb-1">Account</p>
         <p class="text-3xl font-bold tracking-tight flex items-center gap-2">
  <span><%= user?.username || '—' %></span>
  <% if (user?.role === 'admin') { %>
    <span class="px-2 py-0.5 text-xs rounded-full bg-purple-600/20 text-purple-300 border border-purple-700">
      ADMIN
    </span>
  <% } %>
</p>
          <p class="text-zinc-400 mt-2 break-all"><%= user?.email || '—' %></p>
          
        </div>

        

        <div class="group bg-zinc-900 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition p-6">
          <p class="text-zinc-400 text-sm mb-1">Status</p>
          <p class="text-3xl font-bold tracking-tight"><%= user ? 'Logged in' : 'Guest' %></p>
          <p class="text-zinc-400 mt-2">Active session</p>
        </div>
      </section>

     
      <section class="bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden">
        <div class="px-6 py-5 border-b border-zinc-800 flex items-center justify-between">
          <h2 class="text-xl font-semibold">Create a Post</h2>
          <span class="text-zinc-500 text-sm">Share an image with a title</span>
        </div>
        <div class="p-6">
          <% if (typeof error !== 'undefined') { %>
            <p class="text-red-500 mb-4"><%= error %></p>
          <% } %>

         <form method="post" action="/posts" enctype="multipart/form-data" class="grid gap-4 max-w-2xl">
  <div>
    <label class="block text-sm text-zinc-400 mb-1">Title</label>
    <input name="title" placeholder="e.g. Sunset over the hills"
           class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 outline-none focus:ring-2 focus:ring-blue-600"
           required />
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm text-zinc-400 mb-1">Image URL (optional)</label>
      <input name="imageUrl" placeholder="https://images.example.com/photo.jpg"
             class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 outline-none focus:ring-2 focus:ring-blue-600" />
    </div>

    <div>
      <label class="block text-sm text-zinc-400 mb-1">Upload Image (optional)</label>
      <input type="file" name="image" accept="image/*"
             class="w-full px-3 py-2 rounded-lg bg-zinc-800 border border-zinc-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-zinc-700 file:text-white hover:file:bg-zinc-600" />
      <p class="text-xs text-zinc-500 mt-1">Max 5MB. JPG, PNG, WEBP, GIF, AVIF.</p>
    </div>
  </div>

  <div class="flex gap-3">
    <button class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 font-medium">Publish</button>
    <a href="/feed" class="px-4 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700 border border-zinc-700">Cancel</a>
  </div>
</form>

        </div>
      </section>

      <!-- My Posts -->
      <section class="space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Your Posts</h2>
          <span class="text-sm text-zinc-500"><%= (myPosts && myPosts.length) ? myPosts.length : 0 %> total</span>
        </div>

        <% if (!myPosts || !myPosts.length) { %>
          <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
            <p class="text-zinc-400">You haven’t posted anything yet. Create your first post above!</p>
          </div>
        <% } else { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% myPosts.forEach(p => { %>
              <article class="group bg-zinc-900 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition overflow-hidden">
                <div class="relative">
                  <img src="<%= p.imageUrl %>" alt=""
                       class="w-full h-48 object-cover group-hover:brightness-110 transition" />
                </div>
                <div class="p-4 space-y-3">
                  <div>
                    <h3 class="text-lg font-semibold leading-tight"><%= p.title %></h3>
                    <p class="text-xs text-zinc-500"><%= new Date(p.createdAt).toLocaleString() %></p>
                  </div>

                  <div class="flex items-center gap-2">
                    <% const likedByMe = (p.likes || []).some(id => String(id) === String(user._id)); %>
                    <form method="post" action="/posts/<%= p._id %>/<%= likedByMe ? 'unlike' : 'like' %>">
                      <button class="px-3 py-1 rounded-lg text-sm
                                     <%= likedByMe ? 'bg-green-600 hover:bg-green-700' : 'bg-zinc-800 hover:bg-zinc-700 border border-zinc-700' %>">
                        <%= likedByMe ? 'Unlike' : 'Like' %> (<%= (p.likes || []).length %>)
                      </button>
                    </form>

                    <form method="post" action="/posts/<%= p._id %>/delete"
                          onsubmit="return confirm('Delete this post?')">
                      <button class="px-3 py-1 rounded-lg text-sm bg-red-600 hover:bg-red-700">
                        Delete
                      </button>
                    </form>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

    </div>
  </main>

  <footer class="border-t border-zinc-900">
    <div class="max-w-6xl mx-auto px-4 py-6 text-sm text-zinc-500">
      © <%= new Date().getFullYear() %> MiniFB. All rights reserved.
    </div>
  </footer>
</body>
</html>
