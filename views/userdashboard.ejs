<!DOCTYPE html>
<html lang="en">
<head>
  <% /* Ensure user exists BEFORE using it in <title> */ if (typeof user === 'undefined') { var user = {}; } %>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= (user.username || user.email || 'Dashboard') %> — Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white min-h-screen flex flex-col">
<%
  /* ================= SAFE DEFAULTS (single block) ================= */
  if (typeof myPosts === 'undefined' || !Array.isArray(myPosts)) { var myPosts = []; }
  if (typeof followersPreview === 'undefined' || !Array.isArray(followersPreview)) { var followersPreview = []; }
  if (typeof followingPreview === 'undefined' || !Array.isArray(followingPreview)) { var followingPreview = []; }
  if (typeof followersCount !== 'number') { var followersCount = followersPreview.length; }
  if (typeof followingCount !== 'number') { var followingCount = followingPreview.length; }
  var posts = myPosts; // convenience
%>

<!-- HEADER -->
<header class="bg-zinc-900/80 backdrop-blur border-b border-zinc-800 sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 h-14 sm:h-16 flex items-center justify-between">
    <!-- Left: avatar + welcome -->
    <div class="flex items-center gap-3 min-w-0">
      <!-- Clickable avatar (opens modal) -->
      <button type="button" class="group relative w-9 h-9 sm:w-10 sm:h-10 rounded-xl overflow-hidden bg-gradient-to-br from-blue-500 to-indigo-600 grid place-items-center font-bold shrink-0 js-open-avatar-modal" aria-label="Change avatar">
        <% if (user && user.avatarUrl) { %>
          <img src="<%= user.avatarUrl %>" alt="Avatar" class="w-full h-full object-cover" onerror="this.style.display='none'">
        <% } else { %>
          <span class="text-sm sm:text-base"><%= ((user && (user.username || user.email)) ? (user.username || user.email) : '?').trim().charAt(0).toUpperCase() %></span>
        <% } %>
        <span class="absolute inset-0 hidden group-hover:flex items-center justify-center bg-black/50 text-xs font-medium">Change</span>
      </button>

      <div class="leading-tight min-w-0">
        <p class="text-sm sm:text-base font-semibold truncate" title="<%= user && user.email %>">
          Welcome, <span class="text-blue-400"><%= (user && (user.username || user.email)) || 'User' %></span>
        </p>
        <% if (user && user.role) { %>
          <span class="mt-0.5 inline-block align-middle px-2 py-0.5 text-[10px] sm:text-xs rounded-full bg-purple-600/20 text-purple-300 border border-purple-700"><%= String(user.role).toUpperCase() %></span>
        <% } %>
      </div>
    </div>

    <!-- Right: nav -->
    <nav class="hidden md:flex items-center gap-2">
      <!-- ✨ Pretty Messages button (desktop) -->
      <button
        onclick="openChatDrawer()"
        class="group relative inline-flex items-center gap-2 px-4 py-2 rounded-xl
               bg-gradient-to-br from-blue-600 to-indigo-600
               text-white font-medium shadow-[0_8px_20px_rgba(37,99,235,.35)]
               hover:shadow-[0_10px_24px_rgba(37,99,235,.45)]
               hover:from-blue-500 hover:to-indigo-500
               active:scale-[.98]
               border border-white/10
               outline-none focus-visible:ring-2 focus-visible:ring-blue-400/60
               transition">
        <svg class="w-5 h-5 opacity-90 transition group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                d="M21 12c0 4.418-4.03 8-9 8-1.3 0-2.53-.235-3.64-.664L3 20l1.53-3.06C4.19 15.79 3 14.01 3 12 3 7.582 7.03 4 12 4s9 3.582 9 8Z"/>
        </svg>
        <span>Messages</span>
        <span id="unreadBadge"
              class="absolute -top-1.5 -right-1.5 min-w-[18px] h-[18px] px-1
                     rounded-full bg-pink-500 text-[10px] leading-[18px]
                     text-white text-center font-semibold shadow
                     ring-1 ring-white/20 hidden">3</span>
      </button>

      <a href="/feed" class="px-3 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700 transition-colors">Feed</a>
      <a href="/logout" class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700 transition-colors">Logout</a>
    </nav>

    <!-- Mobile menu button -->
    <button id="menuBtn" class="md:hidden p-2 rounded-lg bg-zinc-800 hover:bg-zinc-700" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobileMenu" class="md:hidden hidden border-t border-zinc-800">
    <div class="px-3 py-2 flex flex-col gap-2 bg-zinc-900">
      <!-- ✨ Pretty Messages button (mobile) -->
      <button onclick="openChatDrawer(); mobileMenu.classList.add('hidden')"
              class="px-3 py-2 rounded-lg bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-medium">
        Messages
      </button>
      <a href="/feed" class="px-3 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700">Feed</a>
      <a href="/logout" class="px-3 py-2 rounded-lg bg-red-600 hover:bg-red-700">Logout</a>
    </div>
  </div>
</header>

<!-- AVATAR MODAL -->
<div id="avatarModal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 bg-black/60" onclick="closeAvatarModal()"></div>
  <div class="relative max-w-md mx-auto mt-16 sm:mt-24 bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden">
    <div class="px-4 sm:px-6 py-3 border-b border-zinc-800 flex items-center justify-between">
      <h3 class="font-semibold">Change Profile Picture</h3>
      <button onclick="closeAvatarModal()" class="p-2 rounded-lg hover:bg-zinc-900" aria-label="Close">✕</button>
    </div>
    <div class="p-4 sm:p-6 space-y-4">
      <form method="post" action="/me/avatar" enctype="multipart/form-data" class="space-y-4" id="avatarModalForm">
        <div class="flex items-center gap-3 p-3 rounded-xl bg-zinc-900/60 border border-zinc-800">
          <div class="w-12 h-12 rounded-full overflow-hidden bg-zinc-800 shrink-0">
            <% if (user && user.avatarUrl) { %>
              <img id="avatar-current-modal" src="<%= user.avatarUrl %>" class="w-full h-full object-cover" onerror="this.style.display='none'">
            <% } %>
          </div>
          <div class="text-sm text-zinc-400">Current avatar</div>
        </div>

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1.5">Avatar URL</label>
          <input id="avatar-url-modal" name="avatarUrl" placeholder="https://example.com/avatar.jpg"
                 class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 outline-none focus:ring-2 focus:ring-blue-600">
        </div>

        <div class="text-center text-zinc-500">or</div>

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1.5">Upload Avatar</label>
          <input id="avatar-file-modal" type="file" name="avatar" accept="image/*"
                 class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-zinc-700 file:text-white hover:file:bg-zinc-600">
          <p class="text-xs text-zinc-500 mt-1">PNG/JPG/WEBP/GIF/AVIF up to 5MB</p>
        </div>

        <div class="hidden" id="avatar-preview-wrap-modal">
          <div class="flex items-center gap-3 p-3 rounded-lg bg-zinc-900/40 border border-zinc-800">
            <div class="w-12 h-12 rounded-full overflow-hidden bg-zinc-800">
              <img id="avatar-preview-modal" class="w-full h-full object-cover" alt="">
            </div>
            <span class="text-sm text-zinc-400">Preview</span>
          </div>
        </div>

        <div class="flex items-center justify-end gap-2 pt-2">
          <button type="button" onclick="closeAvatarModal()" class="px-4 py-2 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800">Cancel</button>
          <button class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 font-medium">Update Avatar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- MAIN -->
<main class="flex-1">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 py-6 sm:py-8 space-y-6">

    <!-- PROFILE CARD -->
    <section class="bg-zinc-900 rounded-2xl border border-zinc-800 p-5 sm:p-6">
      <div class="flex items-start gap-4 sm:gap-6">
        <button type="button" class="group relative w-16 h-16 sm:w-20 sm:h-20 rounded-2xl overflow-hidden bg-zinc-800 shrink-0 js-open-avatar-modal" aria-label="Change avatar">
          <% if (user && user.avatarUrl) { %>
            <img src="<%= user.avatarUrl %>" alt="Avatar" class="w-full h-full object-cover" onerror="this.style.display='none'">
          <% } else { %>
            <div class="w-full h-full grid place-items-center text-2xl font-bold text-zinc-400">
              <%= ((user && (user.username || user.email)) ? (user.username || user.email) : '?').trim().charAt(0).toUpperCase() %>
            </div>
          <% } %>
          <span class="absolute inset-0 hidden group-hover:flex items-center justify-center bg-black/50 text-xs font-medium">Change</span>
        </button>

        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-2">
            <h1 class="text-xl sm:text-2xl font-bold truncate"><%= (user && (user.username || 'User')) || 'User' %></h1>
            <% if (user && user.role) { %>
              <span class="px-2 py-0.5 text-xs rounded-full bg-purple-600/20 text-purple-300 border border-purple-700"><%= user.role %></span>
            <% } %>
          </div>
          <p class="text-zinc-400 text-sm break-all mt-1"><%= user && user.email %></p>

          <div class="mt-4 grid grid-cols-3 gap-3">
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-3">
              <p class="text-zinc-400 text-xs">Posts</p>
              <p class="text-lg font-bold"><%= posts.length %></p>
            </div>
            <a href="/u/<%= user && user._id %>/followers" class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-3 hover:border-zinc-700">
              <p class="text-zinc-400 text-xs">Followers</p>
              <p class="text-lg font-bold"><%= followersCount %></p>
            </a>
            <a href="/u/<%= user && user._id %>/following" class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-3 hover:border-zinc-700">
              <p class="text-zinc-400 text-xs">Following</p>
              <p class="text-lg font-bold"><%= followingCount %></p>
            </a>
          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            <button onclick="openPostModal()" class="px-3 sm:px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 font-medium">New Post</button>
            <a href="/u/<%= user && user._id %>" class="px-3 sm:px-4 py-2 rounded-lg bg-zinc-800 hover:bg-zinc-700 border border-zinc-700">Profile</a>
          </div>
        </div>
      </div>
    </section>

    <!-- RECENT POSTS -->
    <section class="bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden">
      <div class="px-4 sm:px-6 py-4 border-b border-zinc-800 flex items-center justify-between">
        <h2 class="text-lg sm:text-xl font-bold">Recent Posts</h2>
        <div class="flex items-center gap-2">
          <input id="postSearch" type="text" placeholder="Search titles..." class="hidden sm:block bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-2 outline-none focus:border-zinc-600 text-sm">
          <button onclick="openPostModal()" class="px-3 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-sm">Create</button>
        </div>
      </div>

      <% if (!posts.length) { %>
        <div class="p-8 text-center text-zinc-400">No posts yet. Create your first post.</div>
      <% } else { %>
        <ul id="postList" class="divide-y divide-zinc-800">
          <% posts.slice(0, 12).forEach(function(p){ var likedByMe = ((p.likes || []).some(function(id){ return String(id) === String(user && user._id); })); %>
          <li class="p-4 sm:p-5 hover:bg-zinc-900/60 transition">
            <div class="flex items-start gap-4">
              <div class="w-24 h-16 rounded-lg overflow-hidden bg-zinc-800 shrink-0 hidden xs:block">
                <% if (p.imageUrl) { %><img src="<%= p.imageUrl %>" alt="" class="w-full h-full object-cover"><% } %>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="font-semibold leading-tight truncate"><%= p.title || 'Untitled' %></h3>
                <p class="text-xs text-zinc-500 mt-0.5"><%= new Date(p.createdAt).toLocaleString() %></p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <form method="post" action="/posts/<%= p._id %>/<%= likedByMe ? 'unlike' : 'like' %>">
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium flex items-center gap-1 <%= likedByMe ? 'bg-pink-600 hover:bg-pink-700' : 'bg-zinc-800 hover:bg-zinc-700 border border-zinc-700' %>">
                      <span><%= likedByMe ? '❤️' : '🤍' %></span>
                      <span><%= likedByMe ? 'Loved' : 'Love' %> (<%= (p.likes || []).length %>)</span>
                    </button>
                  </form>
                  <a href="/posts/<%= p._id %>" class="px-3 py-1.5 rounded-md text-sm bg-zinc-800 hover:bg-zinc-700 border border-zinc-700">Open</a>
                  <form method="post" action="/posts/<%= p._id %>/delete" onsubmit="return confirm('Delete this post?')">
                    <button class="px-3 py-1.5 rounded-md text-sm bg-red-600 hover:bg-red-700">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          </li>
          <% }); %>
        </ul>
      <% } %>
    </section>

    <!-- PEOPLE (compact) -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
      <div class="bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden">
        <div class="px-4 sm:px-6 py-3 border-b border-zinc-800 flex items-center justify-between">
          <h3 class="text-lg font-semibold">Followers <span class="text-zinc-500">(<%= followersCount %>)</span></h3>
          <a href="/u/<%= user && user._id %>/followers" class="text-sm text-zinc-400 hover:text-blue-300">See all →</a>
        </div>
        <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% (followersPreview || []).slice(0,6).forEach(function(f){ %>
          <a href="/u/<%= f._id %>" class="flex items-center gap-3 p-3 rounded-xl bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700">
            <div class="w-10 h-10 rounded-lg overflow-hidden bg-zinc-800 grid place-items-center">
              <% if (f.avatarUrl) { %><img src="<%= f.avatarUrl %>" class="w-full h-full object-cover"><% } else { %>
                <span class="text-sm font-bold"><%= (f.username || f.email || '?').charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium truncate"><%= f.username || f.email %></p>
              <p class="text-xs text-zinc-500 truncate"><%= f.email %></p>
            </div>
          </a>
          <% }); %>
          <% if (!(followersPreview || []).length) { %><p class="text-sm text-zinc-500">No followers yet.</p><% } %>
        </div>
      </div>

      <div class="bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden">
        <div class="px-4 sm:px-6 py-3 border-b border-zinc-800 flex items-center justify-between">
          <h3 class="text-lg font-semibold">Following <span class="text-zinc-500">(<%= followingCount %>)</span></h3>
          <a href="/u/<%= user && user._id %>/following" class="text-sm text-zinc-400 hover:text-blue-300">See all →</a>
        </div>
        <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% (followingPreview || []).slice(0,6).forEach(function(f){ %>
          <a href="/u/<%= f._id %>" class="flex items-center gap-3 p-3 rounded-xl bg-zinc-900/40 border border-zinc-800 hover:border-zinc-700">
            <div class="w-10 h-10 rounded-lg overflow-hidden bg-zinc-800 grid place-items-center">
              <% if (f.avatarUrl) { %><img src="<%= f.avatarUrl %>" class="w-full h-full object-cover"><% } else { %>
                <span class="text-sm font-bold"><%= (f.username || f.email || '?').charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium truncate"><%= f.username || f.email %></p>
              <p class="text-xs text-zinc-500 truncate"><%= f.email %></p>
            </div>
          </a>
          <% }); %>
          <% if (!(followingPreview || []).length) { %><p class="text-sm text-zinc-500">You’re not following anyone yet.</p><% } %>
        </div>
      </div>
    </section>

  </div>
</main>

<footer class="border-t border-zinc-900 mt-10">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 py-5 text-xs sm:text-sm text-zinc-500 text-center">
    © <%= new Date().getFullYear() %> Mosaic. All rights reserved.
  </div>
</footer>

<!-- CREATE POST MODAL -->
<div id="postModal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 bg-black/60" onclick="closePostModal()"></div>
  <div class="relative max-w-xl mx-auto mt-16 sm:mt-24 bg-zinc-950 border border-zinc-800 rounded-2xl overflow-hidden">
    <div class="px-4 sm:px-6 py-3 border-b border-zinc-800 flex items-center justify-between">
      <h3 class="font-semibold">Create Post</h3>
      <button onclick="closePostModal()" class="p-2 rounded-lg hover:bg-zinc-900" aria-label="Close">✕</button>
    </div>
    <div class="p-4 sm:p-6 space-y-4">
      <% if (typeof error !== 'undefined') { %>
        <div class="p-3 rounded-lg bg-red-900/20 border border-red-800 text-red-400 text-sm"><%= error %></div>
      <% } %>
      <form method="post" action="/posts" enctype="multipart/form-data" class="space-y-4" id="createPostForm">
        <div>
          <label class="block text-sm mb-1.5 text-zinc-300">Title</label>
          <input name="title" placeholder="e.g. Beautiful sunset" class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 outline-none focus:ring-2 focus:ring-blue-600" required />
        </div>
        <div>
          <label class="block text-sm mb-1.5 text-zinc-300">Image URL</label>
          <input id="post-url" name="imageUrl" placeholder="https://images.example.com/photo.jpg" class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 outline-none focus:ring-2 focus:ring-blue-600" />
        </div>
        <div class="text-center text-zinc-500">or</div>
        <div>
          <label class="block text-sm mb-1.5 text-zinc-300">Upload Image</label>
          <input id="post-file" type="file" name="image" accept="image/*" class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-zinc-700 file:text-white hover:file:bg-zinc-600" />
          <p class="text-xs text-zinc-500 mt-1">Max 5MB. JPG, PNG, WEBP, GIF, AVIF</p>
        </div>
        <div class="rounded-xl border border-zinc-800 overflow-hidden hidden" id="post-preview-wrap">
          <div class="aspect-[16/9] bg-zinc-900"><img id="post-preview" class="w-full h-full object-cover" alt=""></div>
          <div class="px-3 py-2 text-xs text-zinc-500 border-t border-zinc-800 bg-zinc-900/60">Post preview</div>
        </div>
        <div class="flex items-center justify-end gap-2 pt-2">
          <button type="button" onclick="closePostModal()" class="px-4 py-2 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800">Cancel</button>
          <button class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 font-medium">Publish</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // mobile menu
  const menuBtn = document.getElementById('menuBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

  // create post modal
  function openPostModal(){ document.getElementById('postModal')?.classList.remove('hidden'); }
  function closePostModal(){ document.getElementById('postModal')?.classList.add('hidden'); resetPostPreview(); }

  // avatar modal
  (function(){
    document.querySelectorAll('.js-open-avatar-modal').forEach(function(btn){
      btn.addEventListener('click', function(){ openAvatarModal(); });
    });
    window.openAvatarModal = function(){ document.getElementById('avatarModal')?.classList.remove('hidden'); };
    window.closeAvatarModal = function(){ document.getElementById('avatarModal')?.classList.add('hidden'); resetAvatarPreviewModal(); };

    const url = document.getElementById('avatar-url-modal');
    const file = document.getElementById('avatar-file-modal');
    const wrap = document.getElementById('avatar-preview-wrap-modal');
    const img  = document.getElementById('avatar-preview-modal');

    function render(src){
      if (!wrap || !img) return;
      if (!src){ wrap.classList.add('hidden'); img.removeAttribute('src'); return; }
      img.src = src; wrap.classList.remove('hidden'); img.onerror = function(){ wrap.classList.add('hidden'); };
    }
    url?.addEventListener('input', function(){ if (url.value.trim()) render(url.value.trim()); else if (!(file && file.files && file.files[0])) render(''); });
    file?.addEventListener('change', function(){ var f = file.files && file.files[0]; if (f) render(URL.createObjectURL(f)); else if (!(url && url.value && url.value.trim())) render(''); });
    window.resetAvatarPreviewModal = function(){ if (url) url.value=''; if (file) file.value=''; render(''); };
  })();

  // post preview (modal)
  (function(){
    const urlInput = document.getElementById('post-url');
    const fileInput = document.getElementById('post-file');
    const wrap = document.getElementById('post-preview-wrap');
    const img = document.getElementById('post-preview');
    function render(src){
      if(!wrap || !img) return;
      if(!src){ wrap.classList.add('hidden'); img.removeAttribute('src'); return; }
      img.src = src; wrap.classList.remove('hidden'); img.onerror = function(){ wrap.classList.add('hidden'); };
    }
    urlInput?.addEventListener('input', function(){
      if (urlInput.value.trim()) render(urlInput.value.trim());
      else if (!(fileInput && fileInput.files && fileInput.files[0])) render('');
    });
    fileInput?.addEventListener('change', function(){
      var f = fileInput.files && fileInput.files[0];
      if (f) render(URL.createObjectURL(f));
      else if (!(urlInput && urlInput.value && urlInput.value.trim())) render('');
    });
    window.resetPostPreview = function(){ if (urlInput) urlInput.value=''; if (fileInput) fileInput.value=''; render(''); };
  })();

  // search posts by title
  (function(){
    const input = document.getElementById('postSearch');
    const list = document.getElementById('postList');
    if (!input || !list) return;
    input.addEventListener('input', function(){
      const q = input.value.trim().toLowerCase();
      list.querySelectorAll('li').forEach(function(li){
        const title = (li.querySelector('h3') && li.querySelector('h3').textContent || '').toLowerCase();
        li.style.display = title.includes(q) ? '' : 'none';
      });
    });
  })();

  // helper styles
  const style = document.createElement('style');
  style.textContent = `
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    @media (max-width: 479px) { .xs\\:block { display: none; } }
  `;
  document.head.appendChild(style);
</script>

<!-- ===================== CHAT DRAWER ===================== -->
<div id="chatDrawer" class="fixed inset-0 z-[60] hidden">
  <div class="absolute inset-0 bg-black/60" onclick="closeChatDrawer()"></div>
  <div class="absolute right-0 top-0 h-full w-full max-w-3xl bg-zinc-950 border-l border-zinc-800 grid grid-cols-12">
    <!-- left: chats & mutuals -->
    <div class="col-span-5 border-r border-zinc-800 flex flex-col min-w-0">
      <div class="p-3 sm:p-4 flex items-center justify-between">
        <h3 class="font-semibold">Messages</h3>
        <button class="p-2 rounded-lg hover:bg-zinc-900" onclick="closeChatDrawer()" aria-label="Close">✕</button>
      </div>
      <div class="px-3 sm:px-4 pb-3">
        <input id="chatSearch" type="text" placeholder="Search chats or people..."
          class="w-full px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 outline-none focus:ring-2 focus:ring-blue-600 text-sm">
      </div>
      <div class="px-3 sm:px-4 pb-2 text-xs uppercase tracking-wide text-zinc-500">Your Chats</div>
      <div id="chatList" class="flex-1 overflow-y-auto divide-y divide-zinc-900"></div>
      <div class="px-3 sm:px-4 pt-4 pb-2 text-xs uppercase tracking-wide text-zinc-500 border-t border-zinc-800">Start New (Mutuals)</div>
      <div id="mutualList" class="max-h-48 overflow-y-auto px-3 sm:px-4 pb-4 space-y-2"></div>
    </div>

    <!-- right: thread -->
    <div class="col-span-7 flex flex-col min-w-0">
      <div id="threadHeader" class="p-3 sm:p-4 border-b border-zinc-800 flex items-center gap-3">
        <div id="threadAvatar" class="w-8 h-8 rounded-lg overflow-hidden bg-zinc-800"></div>
        <div class="min-w-0">
          <div id="threadName" class="font-medium truncate">Select a chat</div>
          <div id="threadHint" class="text-xs text-zinc-500 truncate">No conversation selected</div>
        </div>
      </div>
      <div id="threadBody" class="flex-1 overflow-y-auto p-3 sm:p-4 space-y-2 bg-zinc-950"></div>
      <form id="threadForm" class="p-3 sm:p-4 border-t border-zinc-800 flex gap-2" onsubmit="return sendMessage()">
        <input id="threadInput" autocomplete="off" placeholder="Type a message..." maxlength="2000"
               class="flex-1 px-3 py-2 rounded-lg bg-zinc-900 border border-zinc-800 outline-none focus:ring-2 focus:ring-blue-600">
        <button class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 font-medium">Send</button>
      </form>
    </div>
  </div>
</div>

<!-- ===================== CHAT JS ===================== -->
<script>
/* =========================================================================
   Chat UI script (wired to /chats, /chats/:userId, /chats/:userId/messages)
   ========================================================================= */
(function(){
  window.__me = <%- JSON.stringify(user || null) %>;
  window.__followersPreview = <%- JSON.stringify(followersPreview || []) %>;
  window.__followingPreview = <%- JSON.stringify(followingPreview || []) %>;

  const chatDrawer = document.getElementById('chatDrawer');
  function openChatDrawer(){ chatDrawer?.classList.remove('hidden'); buildMutuals(); loadChats(); }
  function closeChatDrawer(){ chatDrawer?.classList.add('hidden'); clearThread(); }
  window.openChatDrawer = openChatDrawer; window.closeChatDrawer = closeChatDrawer;

  const chatListEl = document.getElementById('chatList');
  const mutualListEl = document.getElementById('mutualList');
  const chatSearchEl = document.getElementById('chatSearch');

  const threadHeaderName = document.getElementById('threadName');
  const threadHeaderHint = document.getElementById('threadHint');
  const threadHeaderAvatar = document.getElementById('threadAvatar');
  const threadBodyEl = document.getElementById('threadBody');
  const threadInputEl = document.getElementById('threadInput');

  let currentPeerId = null, currentPeer = null, pollTimer = null;

  function esc(s){ return String(s ?? '').replace(/[&<>"]/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[m])); }
  function fmtTime(ts){ try { return new Date(ts).toLocaleString(); } catch { return ts; } }
  function avatarHTML(src, name, size='w-9 h-9 rounded-lg'){
    if (src) return `<div class="${size} overflow-hidden bg-zinc-800 shrink-0"><img src="${esc(src)}" class="w-full h-full object-cover" onerror="this.parentNode.textContent='${esc((name||'?').charAt(0).toUpperCase())}'"></div>`;
    return `<div class="${size} grid place-items-center bg-zinc-800 shrink-0"><span class="font-bold">${esc((name||'?').charAt(0).toUpperCase())}</span></div>`;
  }
  function postForm(url, dataObj){
    const body = new URLSearchParams(); for (const k in dataObj) body.append(k, dataObj[k]);
    return fetch(url, { method:'POST', headers:{ 'Content-Type':'application/x-www-form-urlencoded' }, body });
  }

  // Build mutuals list (followers ∩ following)
  function buildMutuals(){
    if (!mutualListEl) return;
    const byId = new Map();
    (__followersPreview||[]).forEach(u => byId.set(String(u._id), { ...u, f:true, g:false }));
    (__followingPreview||[]).forEach(u => {
      const id = String(u._id);
      if (byId.has(id)) byId.get(id).g = true; else byId.set(id, { ...u, f:false, g:true });
    });
    const mutuals = Array.from(byId.values()).filter(x => x.f && x.g);
    mutualListEl.innerHTML = mutuals.length ? mutuals.map(m => `
      <div class="flex items-center gap-3 p-2 rounded-lg bg-zinc-900/40 border border-zinc-800">
        ${avatarHTML(m.avatarUrl, m.username || m.email, 'w-8 h-8 rounded-md')}
        <div class="min-w-0">
          <div class="text-sm font-medium truncate">${esc(m.username || m.email || '')}</div>
          <div class="text-xs text-zinc-500 truncate">${esc(m.email || '')}</div>
        </div>
        <button class="ml-auto px-2 py-1 rounded-md bg-blue-600 hover:bg-blue-700 text-xs"
          onclick="startOrOpenChat('${esc(m._id)}','${esc(m.username||m.email||'')}','${esc(m.avatarUrl||'')}')">
          Message
        </button>
      </div>
    `).join('') : `<div class="text-sm text-zinc-500">No mutuals yet.</div>`;
  }

  // Load chats
  async function loadChats(){
    if (!chatListEl) return;
    chatListEl.innerHTML = `<div class="px-4 py-6 text-sm text-zinc-500">Loading chats...</div>`;
    try{
      const r = await fetch('/chats', { headers:{ 'Accept':'application/json' }});
      const chats = await r.json();
      renderChatList(chats);
    }catch{ chatListEl.innerHTML = `<div class="px-4 py-6 text-sm text-red-400">Failed to load chats.</div>`; }
  }

  function renderChatList(chats){
    const items = (chats||[]).map(c => {
      const other = c.other || {};
      const preview = (c.lastMsg && c.lastMsg.text) ? c.lastMsg.text : '';
      const when = (c.lastMsg && c.lastMsg.createdAt) ? fmtTime(c.lastMsg.createdAt) : '';
      return `
        <button class="w-full text-left p-3 hover:bg-zinc-900 transition flex items-center gap-3"
          onclick="openThread('${esc(other._id)}','${esc(other.username||other.email||'')}','${esc(other.avatarUrl||'')}')">
          ${avatarHTML(other.avatarUrl, other.username || other.email)}
          <div class="min-w-0">
            <div class="font-medium truncate">${esc(other.username || other.email || '')}</div>
            <div class="text-xs text-zinc-400 truncate">${esc(preview)}</div>
          </div>
          <div class="ml-auto text-[10px] text-zinc-500 whitespace-nowrap">${esc(when)}</div>
        </button>
      `;
    });
    chatListEl.innerHTML = items.join('') || `<div class="px-4 py-6 text-sm text-zinc-500">No chats yet.</div>`;
  }

  // Open thread
  async function openThread(peerId, name, avatarUrl){
    currentPeerId = String(peerId);
    currentPeer = { _id: peerId, username: name, email: name, avatarUrl: avatarUrl || '' };
    threadHeaderName.textContent = name || 'Chat';
    threadHeaderHint.textContent = 'Chatting privately';
    threadHeaderAvatar.innerHTML = avatarHTML(avatarUrl, name, 'w-8 h-8 rounded-md');
    threadBodyEl.innerHTML = `<div class="px-2 py-4 text-sm text-zinc-500">Loading conversation...</div>`;
    await fetchThreadMessages();
    setTimeout(() => threadInputEl?.focus(), 0);
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(fetchThreadMessages, 5000);
  }
  window.openThread = openThread;

  function clearThread(){
    currentPeerId = null; currentPeer = null;
    if (pollTimer) clearInterval(pollTimer); pollTimer = null;
    threadHeaderName.textContent = 'Select a chat';
    threadHeaderHint.textContent = 'No conversation selected';
    threadHeaderAvatar.innerHTML = '';
    threadBodyEl.innerHTML = '';
    if (threadInputEl) threadInputEl.value = '';
  }

  async function fetchThreadMessages(){
    if (!currentPeerId) return;
    try{
      const r = await fetch(`/chats/${encodeURIComponent(currentPeerId)}`, { headers:{ 'Accept':'application/json' }});
      const data = await r.json();
      renderMessages(data.messages || []);
    }catch{}
  }

  function renderMessages(msgs){
    const meId = String(window.__me && window.__me._id || '');
    const atBottomBefore = (threadBodyEl.scrollHeight - threadBodyEl.scrollTop - threadBodyEl.clientHeight) < 100;
    threadBodyEl.innerHTML = (msgs||[]).map(m => {
      const mine = String(m.from && m.from._id || m.from) === meId;
      const bubble = `
        <div class="max-w-[80%] px-3 py-2 rounded-2xl ${mine ? 'bg-blue-600 text-white' : 'bg-zinc-900 border border-zinc-800'}">
          <div class="text-sm break-words">${esc(m.text)}</div>
          <div class="text-[10px] mt-1 opacity-70">${esc(fmtTime(m.createdAt))}</div>
        </div>`;
      return `
        <div class="flex items-end gap-2 ${mine ? 'justify-end' : ''}">
          ${mine ? '' : avatarHTML(m.from?.avatarUrl, m.from?.username || m.from?.email, 'w-7 h-7 rounded-md')}
          ${bubble}
        </div>`;
    }).join('') || `<div class="px-2 py-6 text-sm text-zinc-500 text-center">Say hi 👋</div>`;
    if (atBottomBefore) threadBodyEl.scrollTop = threadBodyEl.scrollHeight;
  }

  // Start or open chat
  async function startOrOpenChat(peerId, name, avatarUrl){
    try{ await postForm(`/chats/${encodeURIComponent(peerId)}/start`, {}); }catch{}
    openChatDrawer(); openThread(peerId, name, avatarUrl);
  }
  window.startOrOpenChat = startOrOpenChat;

  // Send message
  async function sendMessage(){
    if (!currentPeerId) return false;
    const text = (threadInputEl.value || '').trim();
    if (!text) return false;

    const now = new Date().toISOString();
    threadBodyEl.innerHTML += `
      <div class="flex items-end gap-2 justify-end">
        <div class="max-w-[80%] px-3 py-2 rounded-2xl bg-blue-600 text-white">
          <div class="text-sm break-words">${esc(text)}</div>
          <div class="text-[10px] mt-1 opacity-70">${esc(fmtTime(now))}</div>
        </div>
      </div>`;
    threadBodyEl.scrollTop = threadBodyEl.scrollHeight;
    threadInputEl.value = '';

    try{
      await postForm(`/chats/${encodeURIComponent(currentPeerId)}/messages`, { text });
      fetchThreadMessages(); loadChats();
    }catch{}
    return false;
  }
  window.sendMessage = sendMessage;

  // Search filter for chats + mutuals
  chatSearchEl?.addEventListener('input', () => {
    const q = chatSearchEl.value.trim().toLowerCase();
    Array.from(chatListEl.children).forEach(el => { const txt = (el.textContent || '').toLowerCase(); el.style.display = txt.includes(q) ? '' : 'none'; });
    Array.from(mutualListEl.children).forEach(el => { const txt = (el.textContent || '').toLowerCase(); el.style.display = txt.includes(q) ? '' : 'none'; });
  });

  // Optional helper: update unread badge (call setUnreadCount(0) to hide)
  window.setUnreadCount = function(n){
    const b = document.getElementById('unreadBadge'); if (!b) return;
    if (!n) { b.classList.add('hidden'); return; }
    b.textContent = n > 99 ? '99+' : n; b.classList.remove('hidden');
  };
})();
</script>

</body>
</html>
